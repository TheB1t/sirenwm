-- SirenWM minimal example config
-- Copy to ~/.config/sirenwm/init.lua and adjust to your setup.

-- Modules to load. Order matters — each module's config keys become
-- available only after the module is listed here.
siren.modules = { "bar", "monitors", "layout", "rules", "keybindings", "process" }

-- Primary modifier key (mod4 = super/win)
siren.modifier = "mod4"

-- Monitor layout. Use xrandr to find your output names.
siren.monitors = {
    {
        name     = "primary",
        output   = "HDMI-1",
        width    = 1920,
        height   = 1080,
        refresh  = 60,
        rotation = "normal",
        enabled  = true,
    },
}

siren.compose_monitors = {
    primary = "primary",
    layout  = {
        { monitor = "primary" },
    },
}

-- Workspaces assigned to monitors by alias.
siren.workspaces = {
    { name = "[1]", monitor = "primary" },
    { name = "[2]", monitor = "primary" },
    { name = "[3]", monitor = "primary" },
    { name = "[4]", monitor = "primary" },
    { name = "[5]", monitor = "primary" },
}

-- Theme: colors and display metrics used by bar, borders, and dmenu helpers.
siren.theme = {
    font   = "monospace:size=9",
    bg     = "#111111",
    fg     = "#bbbbbb",
    alt_bg = "#222222",
    alt_fg = "#eeeeee",
    accent = "#005577",
    gap    = 4,
    border = {
        thickness  = 1,
        focused    = "#005577",
        unfocused  = "#222222",
    },
}

-- Behavior
siren.behavior = {
    follow_moved_window = false,
    focus_new_window    = true,
}

-- Mouse drag bindings
siren.mouse = {
    { "mod+Button1", "move"   },
    { "mod+Button3", "resize" },
    { "mod+Button2", "float"  },
}

-- Tiling layout
siren.layout = {
    name          = "tile",
    master_factor = 0.55,
}

-- Status bar
siren.bar = {
    top = {
        height = 18,
        left   = { "tags" },
        center = { "title" },
        right  = { "tray", "clock" },
    },
    widgets = {
        clock = function() return os.date(" %H:%M ") end,
    },
}

-- Autostart processes
siren.autostart = {
    { cmd = "picom", policy = "once" },
}

-- Window rules (workspace is 1-indexed)
siren.rules = {
    { class = "firefox", workspace = 2 },
}

-- Keybindings
siren.binds = {
    { "mod+Return",      function() siren.spawn("xterm") end },
    { "mod+p",           function()
        local t = siren.theme_get()
        local m = siren.monitor.focused()
        siren.spawn(string.format(
            "dmenu_run -m %d -fn '%s' -nb '%s' -nf '%s' -sb '%s' -sf '%s'",
            m.index, t.font, t.bg, t.fg, t.accent, t.bg))
    end },

    { "mod+shift+q",     function() siren.windows.close() end },

    { "mod+j",           function() siren.windows.focus_next() end },
    { "mod+k",           function() siren.windows.focus_prev() end },
    { "mod+shift+Return",function() siren.windows.zoom() end },
    { "mod+shift+space", function() siren.windows.toggle_floating() end },

    { "mod+h",           function() siren.windows.adj_master_factor(-0.05) end },
    { "mod+l",           function() siren.windows.adj_master_factor( 0.05) end },
    { "mod+i",           function() siren.windows.inc_master( 1) end },
    { "mod+d",           function() siren.windows.inc_master(-1) end },

    { "mod+m",           function() siren.windows.set_layout("monocle") end },
    { "mod+t",           function() siren.windows.set_layout("tile") end },

    { "mod+r",           function() siren.reload() end },
    { "mod+shift+r",     function() siren.restart() end },
}

-- Workspace switch and move bindings (1–9)
for i = 1, 9 do
    table.insert(siren.binds, { "mod+"       .. i, function() siren.workspace.switch(i) end })
    table.insert(siren.binds, { "mod+shift+" .. i, function() siren.windows.move_to(i)  end })
end
